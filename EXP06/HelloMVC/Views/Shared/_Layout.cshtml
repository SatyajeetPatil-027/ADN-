<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HelloMVC</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">ASP.NET-Core MVC</a>
            <div class="navbar-nav">
                <a class="nav-link" asp-controller="Home" asp-action="Index">HOME</a>
                <a class="nav-link" asp-controller="Home" asp-action="About">ABOUT</a>
                <a class="nav-link" asp-controller="Home" asp-action="Privacy">PRIVACY</a>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <footer class="text-center mt-5 py-3 bg-light">
        <p>&copy; 2024 HelloMVC - Experiment 06 ASP.NET Core MVC</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js">
    </script>
</body>
</html>