@{
    ViewData["Title"] = "About";
}

<div class="container mt-4">
    <h2>Experiment Details</h2>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Student Name</dt>
        <dd class="col-sm-9">@ViewBag.StudentName</dd>

        <dt class="col-sm-3">PRN</dt>
        <dd class="col-sm-9">@ViewBag.PRN</dd>

        <dt class="col-sm-3">Subject</dt>
        <dd class="col-sm-9">@ViewBag.Subject</dd>

        <dt class="col-sm-3">Experiment Name</dt>
        <dd class="col-sm-9">@ViewBag.ExperimentName</dd>
    </dl>
    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
        Back to Home
    </a>
</div>