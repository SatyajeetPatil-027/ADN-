@model campusMaintainance_Tracker.Models.MaintenanceRequest

@{
    ViewData["Title"] = "Delete Request";
}

<div class="container mt-4">
    <h2>Delete Maintenance Request</h2>

    <div class="alert alert-danger mt-3">
        Are you sure you want to delete this request?
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <p><strong>Title:</strong> @Model.Title</p>
            <p><strong>Description:</strong> @Model.Description</p>
            <p><strong>Category:</strong> @Model.Category</p>
            <p><strong>Priority:</strong> @Model.Priority</p>
            <p><strong>Status:</strong> @Model.Status</p>
            <p><strong>Location:</strong> @Model.Location</p>
        </div>
    </div>

    <form asp-action="Delete" method="post" class="mt-3">
        <input type="hidden" asp-for="RequestId" />

        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>